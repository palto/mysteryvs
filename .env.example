# Liveblocks secret key for real-time collaboration
LIVEBLOCKS_SECRET=

# Secret used to sign session cookies (>=32 chars). Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# --- Local development against the Liveblocks dev server (optional) ---
# Run `npm run dev:liveblocks` in a separate terminal, then use these values
# instead of a real Liveblocks secret key:
#   LIVEBLOCKS_SECRET=sk_localdev
#   LIVEBLOCKS_BASE_URL=http://localhost:1153
#   NEXT_PUBLIC_LIVEBLOCKS_BASE_URL=http://localhost:1153
# Leave the BASE_URL variables unset to connect to the Liveblocks cloud.
LIVEBLOCKS_BASE_URL=
NEXT_PUBLIC_LIVEBLOCKS_BASE_URL=
